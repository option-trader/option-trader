# Copy to .env.local and fill in. NEVER commit .env.local.

# ---- Upstox (from https://account.upstox.com/developer/apps) ----
# The redirect URL below must EXACTLY match the one configured in the Upstox app.
NEXT_PUBLIC_UPSTOX_API_KEY=
UPSTOX_API_SECRET=
NEXT_PUBLIC_UPSTOX_REDIRECT_URL=http://localhost:3000/auth/callback

# ---- Token encryption (required for Upstox login) ----
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=

# ---- Supabase (optional — app works without it; run supabase/schema.sql first) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NODE_ENV=development
